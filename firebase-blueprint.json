{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A chat message sent by a survivor",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The message content"
        },
        "uid": {
          "type": "string",
          "description": "The sender's GitHub UID"
        },
        "displayName": {
          "type": "string",
          "description": "The sender's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The sender's avatar URL"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the message was created"
        }
      },
      "required": ["text", "uid", "displayName", "createdAt"]
    },
    "Presence": {
      "title": "Presence",
      "description": "The online presence status of an authorized user",
      "type": "object",
      "properties": {
        "lastActive": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp of the user's last active heartbeat"
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the online user"
        }
      },
      "required": ["lastActive"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "jungleFeverSpoiler": {
          "type": "boolean",
          "description": "Show/Hide Jungle Fever spoiler"
        }
      }
    },
    "NewsItem": {
      "title": "NewsItem",
      "description": "A news post in the news feed",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["updates", "blogs", "events"] },
        "title": { "type": "object" },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "badge": { "type": "object" },
        "isFeatured": { "type": "boolean" },
        "coverImage": { "type": "string" },
        "summary": { "type": "object" },
        "content": { "type": "object" }
      }
    },
    "ChatUser": {
      "title": "ChatUser",
      "description": "Profile data for chat participants",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "avatarClass": { "type": "string" },
        "role": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "isVip": { "type": "boolean" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "USDT TRC20 Payment verification details",
      "type": "object",
      "properties": {
        "txId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "plan": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "verifiedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["txId", "userId", "amount", "plan", "status", "createdAt"]
    }
  },
  "firestore": {
    "/payments/{txId}": {
      "schema": "Payment",
      "description": "USDT TRC20 Payments and subscriptions tracker"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global chat messages collection"
    },
    "/presence/{userId}": {
      "schema": "Presence",
      "description": "Real-time presence collection"
    },
    "/site_settings/{docId}": {
      "schema": "SiteSettings",
      "description": "Global site settings"
    },
    "/news/{newsId}": {
      "schema": "NewsItem",
      "description": "Game news and updates"
    },
    "/chat_users/{userId}": {
      "schema": "ChatUser",
      "description": "User profiles and permissions"
    },
    "/messages/{messageId}": {
      "description": "Chat messages"
    },
    "/presence/{userId}": {
      "description": "User presence tracking"
    },
    "/site_settings/announcement": {
      "description": "Global announcement"
    },
    "/site_settings/twitch": {
      "description": "Twitch integration settings"
    },
    "/site_settings/jungle_fever_spoiler": {
      "description": "Spoiler visibility toggle"
    },
    "/site_settings/maintenance_mode": {
      "description": "Global maintenance mode toggle"
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global catch-all deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Global chat messages
    match /messages/{messageId} {
      allow read: if true;
      allow write: if true;
    }

    // Presence tracking
    match /presence/{userId} {
      allow read, write: if true;
    }

    // Registered chat users
    match /chat_users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Metadata configuration tracking
    match /chat_metadata/{docId} {
      allow read, write: if true;
    }
    
    // Site settings
    match /site_settings/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
